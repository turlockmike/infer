#!/usr/bin/env python3
"""infer — pipe-friendly LLM agent with a bash tool.

Works with any OpenAI-compatible provider: Ollama, LM Studio, Groq,
OpenRouter, Together AI, vLLM, OpenAI, etc.

Usage:
  infer "question"
  cat file | infer "question about it"
  infer -f crash.log "why did this fail"
  infer -r coder "fix this"
  infer -m qwen3:latest "question"
  infer -u https://api.groq.com/openai/v1 -k $GROQ_API_KEY -m llama3-70b-8192 "question"
"""

import argparse, json, os, subprocess, sys
from pathlib import Path
from openai import OpenAI

GLOBAL_CONFIG = Path.home() / ".config" / "infer" / "config.json"
GLOBAL_SYSTEM = Path.home() / ".config" / "infer" / "system.md"
GLOBAL_ROLES  = Path.home() / ".config" / "infer" / "roles"
LOCAL_CONFIG  = Path(".infer.json")
LOCAL_SYSTEM  = Path(".infer.md")

DEFAULTS = {
    "url":     "http://192.168.4.30:11434/v1",
    "model":   "gemma4:latest",
    "api_key": "ollama",
}

DEFAULT_SYSTEM = """You have one tool: bash. Use it for everything.

Your final message is the output of this program — it will be printed to stdout and may be piped into other commands. Be concise and output only what was asked for. No preamble, no commentary.

File conventions:
- Read files with: cat -n <path>
- List directories with: ls -la <path>
- Write files: cat the file first if it exists, then write full content with tee <path> <<'EOF'\n...\nEOF
- Never overwrite a file without reading it first unless explicitly told to."""

TOOLS = [{
    "type": "function",
    "function": {
        "name": "bash",
        "description": "Run a shell command, return stdout+stderr",
        "parameters": {
            "type": "object",
            "properties": {
                "command": {"type": "string", "description": "Shell command to run"}
            },
            "required": ["command"],
        },
    },
}]


def load_config():
    cfg = dict(DEFAULTS)
    system_parts = []
    for config_path, system_path in [(GLOBAL_CONFIG, GLOBAL_SYSTEM), (LOCAL_CONFIG, LOCAL_SYSTEM)]:
        if Path(config_path).exists():
            cfg.update(json.loads(Path(config_path).read_text()))
        if Path(system_path).exists():
            system_parts.append(Path(system_path).read_text().strip())
    cfg["system"] = "\n\n".join(system_parts) if system_parts else DEFAULT_SYSTEM
    return cfg


def load_role(name: str) -> str:
    role_path = GLOBAL_ROLES / f"{name}.md"
    if not role_path.exists():
        print(f"infer: role '{name}' not found at {role_path}", file=sys.stderr)
        sys.exit(1)
    return role_path.read_text().strip()


def validate_shape(data, shape):
    if isinstance(shape, dict):
        if not isinstance(data, dict):
            return f"expected object, got {type(data).__name__}"
        for key in shape:
            if key not in data:
                return f"missing key '{key}'"
            err = validate_shape(data[key], shape[key])
            if err:
                return f"['{key}']: {err}"
    elif isinstance(shape, list):
        if not isinstance(data, list):
            return f"expected array, got {type(data).__name__}"
        if shape and data:
            for i, item in enumerate(data):
                err = validate_shape(item, shape[0])
                if err:
                    return f"[{i}]: {err}"
    elif isinstance(shape, str):
        if not isinstance(data, str):
            return f"expected string, got {type(data).__name__}"
    elif isinstance(shape, (int, float)):
        if not isinstance(data, (int, float)):
            return f"expected number, got {type(data).__name__}"
    elif isinstance(shape, bool):
        if not isinstance(data, bool):
            return f"expected boolean, got {type(data).__name__}"
    return None


def run(prompt: str, url: str, model: str, api_key: str, system: str, verbose: bool, json_mode=False, max_steps: int = 10):
    client = OpenAI(base_url=url, api_key=api_key)
    messages = [
        {"role": "system", "content": system},
        {"role": "user",   "content": prompt},
    ]

    if verbose:
        print(f"model={model} url={url}", file=sys.stderr)

    for step in range(1, max_steps + 1):
        resp = client.chat.completions.create(model=model, messages=messages, tools=TOOLS)
        msg = resp.choices[0].message

        if msg.tool_calls:
            for call in msg.tool_calls:
                cmd = json.loads(call.function.arguments).get("command", "")
                result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
                output = (result.stdout + result.stderr).strip() or "(no output)"
                if verbose:
                    print(f"+ {cmd}", file=sys.stderr)
                    print(output, file=sys.stderr)
                messages.append(msg)
                messages.append({"role": "tool", "tool_call_id": call.id, "content": output})
        else:
            content = msg.content or ""
            if json_mode:
                try:
                    parsed = json.loads(content)
                except json.JSONDecodeError as e:
                    print(f"infer: invalid JSON: {e}", file=sys.stderr)
                    messages.append(msg)
                    messages.append({"role": "user", "content": (
                        f"Your response was not valid JSON. Error: {e}\n"
                        f"You returned: {content}\n"
                        f"Fix it and respond with valid JSON only. No markdown, no code fences, no explanation."
                    )})
                    continue
                if isinstance(json_mode, str):
                    err = validate_shape(parsed, json.loads(json_mode))
                    if err:
                        print(f"infer: shape mismatch: {err}", file=sys.stderr)
                        messages.append(msg)
                        messages.append({"role": "user", "content": (
                            f"Your response was invalid. Problem: {err}\n"
                            f"You returned: {content}\n"
                            f"Required shape: {json_mode}\n"
                            f"Fix it and respond with valid JSON matching that shape exactly. Nothing else."
                        )})
                        continue
            print(content)
            if verbose:
                usage = resp.usage
                print(f"[{usage.completion_tokens} tok, prompt={usage.prompt_tokens}]", file=sys.stderr)
            return 0

    print("infer: max steps reached", file=sys.stderr)
    return 1


VALID_KEYS = {"url", "model", "api_key"}

def cmd_config(args):
    GLOBAL_CONFIG.parent.mkdir(parents=True, exist_ok=True)
    current = json.loads(GLOBAL_CONFIG.read_text()) if GLOBAL_CONFIG.exists() else {}

    if args.config_cmd == "show":
        merged = {**DEFAULTS, **current}
        for k, v in merged.items():
            print(f"{k}={v}")

    elif args.config_cmd == "get":
        if args.key not in VALID_KEYS:
            print(f"infer config: unknown key '{args.key}'. Valid: {', '.join(VALID_KEYS)}", file=sys.stderr)
            sys.exit(1)
        merged = {**DEFAULTS, **current}
        print(merged.get(args.key, ""))

    elif args.config_cmd == "set":
        if args.key not in VALID_KEYS:
            print(f"infer config: unknown key '{args.key}'. Valid: {', '.join(VALID_KEYS)}", file=sys.stderr)
            sys.exit(1)
        current[args.key] = args.value
        GLOBAL_CONFIG.write_text(json.dumps(current, indent=2))
        print(f"{args.key}={args.value}")

    elif args.config_cmd == "unset":
        if args.key in current:
            del current[args.key]
            GLOBAL_CONFIG.write_text(json.dumps(current, indent=2))
        print(f"unset {args.key}")

    else:
        print("usage: infer config <show|get|set|unset> [key] [value]")
        sys.exit(1)


def check_config():
    """Warn on first run if no config exists."""
    if not GLOBAL_CONFIG.exists() and not LOCAL_CONFIG.exists():
        print("infer: no config found. Run:", file=sys.stderr)
        print("  infer config set url http://localhost:11434/v1", file=sys.stderr)
        print("  infer config set model gemma4:latest", file=sys.stderr)
        print("  infer config set api_key ollama", file=sys.stderr)
        print("", file=sys.stderr)
        print("  Common providers:", file=sys.stderr)
        print("    Ollama:     url=http://localhost:11434/v1      api_key=ollama", file=sys.stderr)
        print("    Groq:       url=https://api.groq.com/openai/v1  api_key=<key>", file=sys.stderr)
        print("    OpenRouter: url=https://openrouter.ai/api/v1    api_key=<key>", file=sys.stderr)
        print("    OpenAI:     url=https://api.openai.com/v1       api_key=<key>", file=sys.stderr)
        print("", file=sys.stderr)
        print("  Proceeding with built-in defaults...", file=sys.stderr)
        print("", file=sys.stderr)


if __name__ == "__main__":
    # Route config subcommand before loading config
    if len(sys.argv) > 1 and sys.argv[1] == "config":
        p = argparse.ArgumentParser(prog="infer config")
        sub = p.add_subparsers(dest="config_cmd")
        sub.add_parser("show")
        g = sub.add_parser("get");   g.add_argument("key")
        s = sub.add_parser("set");   s.add_argument("key"); s.add_argument("value")
        u = sub.add_parser("unset"); u.add_argument("key")
        cmd_config(p.parse_args(sys.argv[2:]))
        sys.exit(0)

    check_config()
    cfg = load_config()

    parser = argparse.ArgumentParser(description="Pipe-friendly LLM agent", add_help=True)
    parser.add_argument("prompt", nargs="?", help="Prompt (reads stdin if omitted)")
    parser.add_argument("-m", "--model",   default=cfg["model"],   metavar="MODEL")
    parser.add_argument("-u", "--url",     default=cfg["url"],     metavar="URL")
    parser.add_argument("-k", "--api-key", default=cfg["api_key"], metavar="KEY",
                        help="API key (default: 'ollama' for local providers)")
    parser.add_argument("-s", "--system",  default=cfg["system"],  metavar="TEXT")
    parser.add_argument("-r", "--role",    default=None,           metavar="ROLE",
                        help="Named role from ~/.config/infer/roles/<name>.md (overrides -s)")
    parser.add_argument("-f", "--file",    default=None,           metavar="FILE",
                        help="File to use as context (prepended to prompt)")
    parser.add_argument("-j", "--json",    nargs="?", const=True,  metavar="SHAPE",
                        help="Output JSON, optionally with a shape hint")
    parser.add_argument("-v", "--verbose", action="store_true")
    args = parser.parse_args()

    system = load_role(args.role) if args.role else args.system
    if args.json:
        system += "\n\nRespond with valid JSON only. No markdown, no code fences, no explanation. If the result is a list, return a JSON array with one element per item — never a single string with newlines."
        if isinstance(args.json, str):
            system += f"\n\nThe response must match this shape exactly: {args.json}"

    file_context = Path(args.file).read_text().strip() if args.file else None
    stdin_data = sys.stdin.read().strip() if not sys.stdin.isatty() else None

    parts = [p for p in [file_context, stdin_data] if p]
    context = "\n\n".join(parts)

    if context and args.prompt:
        prompt = f"{context}\n\n{args.prompt}"
    elif context:
        prompt = context
    elif args.prompt:
        prompt = args.prompt
    else:
        parser.print_help()
        sys.exit(1)

    json_mode = args.json if args.json else False
    sys.exit(run(prompt, url=args.url, model=args.model, api_key=args.api_key,
                 system=system, verbose=args.verbose, json_mode=json_mode))
